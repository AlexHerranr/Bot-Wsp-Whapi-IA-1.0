  totalPayments  String?  // "75000"
  balance        String?  // "75000" 
  basePrice      String?  // "140000"
  
  // 📊 ORIGEN Y CONTACTO (Prioridad 6)
  channel        String?  // Canal de reserva
  email          String?
  country        String?  // País del huésped
  guestLang      String?  // "es", "en" - idioma del huésped para WhatsApp
  apiReference   String?
  
  // 💳 TRANSACCIONES DETALLADAS (Prioridad 7) - Arrays por defecto
  charges        Json     @default("[]")  // Array siempre, nunca null
  payments       Json     @default("[]")  // Array siempre, nunca null
  
  // 💬 CONVERSACIÓN Y EVENTOS (Prioridad 7.5)
  messages       Json     @default("[]")  // [{"id":123,"time":"2025-08-12T06:04:18Z","source":"guest","direction":"in","text":"Hola"}]
  infoItems      Json     @default("[]")  // [{"code":"door_code","text":"1234","time":"2024-01-15T10:00:00Z"}]
  
