// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model ClientView {
  phoneNumber         String   @id
  name                String?  // Mantener como viene de Whapi
  userName            String?
  labels              String?  // Labels concatenados con "/" (ej: "VIP/Hotel/Premium")
  chatId              String?  @unique  // CLAVE: Evita duplicados por chatId
  lastActivity        DateTime @updatedAt
  threadId            String?
  threadTokenCount    Int?     @default(0)  // Tokens del thread actual
  profileStatus       String?   @db.Text
  proximaAccion       String?
  fechaProximaAccion  DateTime?
  prioridad           Int?
}

// Tabla simplificada para datos estáticos de apartamentos
model HotelApartment {
  id           Int     @id @default(autoincrement())
  propertyId   Int     @map("property_id")
  roomId       Int     @unique @map("room_id")  
  roomName     String  @map("room_name")
  extraCharge  Json    @default("{\"description\": \"Cargo adicional:\", \"amount\": 70000}") @map("extra_charge")
  
  @@map("hotel_apartments")
}

// 📚 RESERVAS PASADAS - Check-out ≤ 2025-08-11 (ya completadas)
model ReservationsPast {
  id             Int      @id @default(autoincrement())
  
  // 🎯 INFORMACIÓN CRÍTICA (Prioridad 1)
  bookingId      String   @unique
  phone          String   // requerido porque filtramos sólo reservas con teléfono
  guestName      String?  // "Juan Pérez" - nombre completo simple
  status         String?  // confirmed, cancelled, etc (tal como viene de Beds24)
  internalNotes  String?  // message de Beds24 - notas internas
  
  // 🏨 UBICACIÓN (Prioridad 2)  
  propertyName   String?  // Nombre de la propiedad (suficiente sin ID)
  
  // 📅 FECHAS DE ESTADÍA (Prioridad 3) - Formato simple YYYY-MM-DD
  arrivalDate    String?  // "2024-01-15" - formato limpio
  departureDate  String?  // "2024-01-16" - formato limpio
  numNights      Int?
  
  // 👥 OCUPACIÓN (Prioridad 4)
  totalPersons   Int?     // 3 - número total simple
  
  // 💰 FINANCIEROS (Prioridad 5) - String para mantener formato original
  totalCharges   String?  // "150000" (sin decimales como viene de API)
  totalPayments  String?  // "75000"
  balance        String?  // "75000" 
  basePrice      String?  // "140000"
  
  // 📊 ORIGEN Y CONTACTO (Prioridad 6)
  channel        String?  // Canal de reserva
  email          String?
  country        String?  // País del huésped
  guestLang      String?  // "es", "en" - idioma del huésped para WhatsApp
  apiReference   String?
  
  // 💳 TRANSACCIONES DETALLADAS (Prioridad 7) - Arrays por defecto
  charges        Json     @default("[]")  // Array siempre, nunca null
  payments       Json     @default("[]")  // Array siempre, nunca null
  
  // 💬 CONVERSACIÓN Y EVENTOS (Prioridad 7.5)
  messages       Json     @default("[]")  // [{"id":123,"time":"2025-08-12T06:04:18Z","source":"guest","direction":"in","text":"Hola"}]
  infoItems      Json     @default("[]")  // [{"code":"door_code","text":"1234","time":"2024-01-15T10:00:00Z"}]
  
  // 📝 NOTAS Y FECHAS DE SISTEMA (Prioridad 8)
  notes          String?
  bookingDate    String?  // "2024-01-10" - cuándo se hizo la reserva
  modifiedDate   String?  // "2024-01-12" - última modificación en Beds24
  
  // 🕐 CONTROL INTERNO BD
  lastUpdatedBD  DateTime @default(now()) @updatedAt  // Se actualiza automáticamente cada vez que se modifica la fila
  
  // 🗂️ BACKUP COMPLETO (Prioridad 9)
  raw            Json?    // JSON con toda la respuesta de API

  // 🚀 ÍNDICES ESTRATÉGICOS para performance
  @@index([departureDate])                  // Filtros por checkout (clave para pasadas)
  @@index([arrivalDate])                    // Filtros por fecha
  @@index([status])                         // Filtros por estado
  @@index([propertyName, departureDate])    // Listados por propiedad + checkout
  @@index([phone])                          // Búsquedas por teléfono (WhatsApp)
  @@index([guestName])                      // Búsquedas por nombre
}

