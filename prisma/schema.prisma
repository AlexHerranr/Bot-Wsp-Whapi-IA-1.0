generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClientView {
  phoneNumber        String    @id
  name               String?
  userName           String?
  labels             String?
  chatId             String?   @unique
  lastActivity       DateTime  @updatedAt
  threadId           String?
  threadTokenCount   Int?      @default(0)
  profileStatus      String?
  proximaAccion      String?
  fechaProximaAccion DateTime?
  prioridad          Int?
}

model HotelApartment {
  id          Int    @id @default(autoincrement())
  propertyId  Int    @map("property_id")
  roomId      Int    @unique @map("room_id")
  roomName    String @map("room_name")
  extraCharge Json   @default("{\"amount\": 70000, \"description\": \"Cargo adicional:\"}") @map("extra_charge")

  @@map("hotel_apartments")
}

// 📚 BOOKING - TODAS LAS RESERVAS CON TELÉFONO (Estructura original limpia)
model Booking {
  id            Int      @id @default(autoincrement())
  bookingId     String   @unique
  phone         String?
  guestName     String?
  status        String?
  internalNotes String?
  propertyName  String?
  arrivalDate   String?
  departureDate String?
  numNights     Int?
  totalPersons  Int?
  totalCharges  String?
  totalPayments String?
  balance       String?
  basePrice     String?
  channel       String?
  email         String?
  apiReference  String?
  charges       Json     @default("[]")
  payments      Json     @default("[]")
  messages      Json     @default("[]")
  infoItems     Json     @default("[]")
  notes         String?
  bookingDate   String?
  modifiedDate  String?
  lastUpdatedBD DateTime @default(now()) @updatedAt
  BDStatus      String?  // Clasificación automática: Futura Confirmada, Futura Pendiente, Cancelada Futura, Cancelada Pasada
  raw           Json?

  @@index([departureDate])
  @@index([arrivalDate])
  @@index([status])
  @@index([propertyName, departureDate])
  @@index([phone])
  @@index([guestName])
  @@index([bookingId])
  @@index([channel])
  @@index([modifiedDate])
}

// 🎯 LEADS COMERCIALES - Solo futuras con datos esenciales
model Leads {
  id                Int       @id @default(autoincrement())
  
  // 🔗 REFERENCIA
  bookingId         String?   // ID de Booking si viene de ahí, null si es directo
  
  // 👤 DATOS BÁSICOS
  phone             String    // Teléfono (obligatorio)
  guestName         String?   // Nombre del cliente
  
  // 🏨 SOLICITUD
  propertyName      String?   // Apartamento solicitado
  arrivalDate       String    // Fecha llegada (obligatorio, solo futuras)
  departureDate     String?   // Fecha salida
  totalPersons      Int?      // Número de personas
  
  // 💰 VALOR
  estimatedValue    String?   // Valor estimado/cotizado
  
  // 🎯 TIPO DE LEAD (4 tipos)
  leadType          String    // 'Descartado', 'Cotizando', 'Booking/New', 'Direct/Confirmed'
  
  // 📊 ORIGEN
  source            String    // 'beds24', 'whatsapp', 'direct'
  channel           String?   // Canal original (Booking.com, Direct, etc.)
  
  // 🚨 GESTIÓN
  priority          String    @default("media")  // alta, media, baja
  assignedTo        String?   // Responsable
  
  // 📅 SEGUIMIENTO
  lastContactAt     DateTime? // Última vez contactado
  nextFollowUp      DateTime? // Próximo seguimiento
  notes             String?   // Notas comerciales
  
  // 🕐 CONTROL
  createdAt         DateTime  @default(now())
  lastUpdated       DateTime  @default(now()) @updatedAt

  // 🚀 ÍNDICES OPTIMIZADOS
  @@index([leadType])          // Filtrar por tipo
  @@index([arrivalDate])       // Ordenar por fecha
  @@index([phone])             // Búsqueda WhatsApp
  @@index([priority])          // Filtrar prioridad
  @@index([assignedTo])        // Leads por responsable
  @@index([source])            // Filtrar por origen
  @@index([lastContactAt])     // Leads sin gestionar
  @@index([nextFollowUp])      // Agenda seguimiento
}

// 🤖 IA CRM CLIENTES - Gestión comercial independiente
model IA_CMR_Clientes {
  phoneNumber        String    @id
  profileStatus      String?   // VIP, Regular, Problemático, etc.
  proximaAccion      String?   // Llamar, Email, WhatsApp, etc.
  fechaProximaAccion DateTime? // Cuándo hacer seguimiento
  prioridad          Int?      // 1=Alta, 2=Media, 3=Baja

  @@index([prioridad])
  @@index([fechaProximaAccion])
}
